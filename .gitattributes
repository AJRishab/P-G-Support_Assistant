# Normalize line endings to LF in the repository on all platforms.
* text=auto eol=lf

# Explicitly mark source/text files.
*.py    text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf

# Binary files — never normalize or diff.
*.db     binary
*.png    binary
*.jpg    binary
*.jpeg   binary
*.ico    binary
*.pdf    binary
